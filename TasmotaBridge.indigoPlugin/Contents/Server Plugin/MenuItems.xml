<?xml version="1.0" encoding="UTF-8"?>
<MenuItems>

    <MenuItem id="discoverDevices">
        <Name>Discover Tasmota Devices</Name>
        <CallbackMethod>discoverDevices</CallbackMethod>
    </MenuItem>

    <MenuItem id="listSeenDevices">
        <Name>List Seen Devices</Name>
        <CallbackMethod>listSeenDevices</CallbackMethod>
    </MenuItem>

    <MenuItem id="dumpDiscoveryCache">
        <Name>Dump Discovery Cache to Log</Name>
        <CallbackMethod>dumpDiscoveryCache</CallbackMethod>
    </MenuItem>

    <MenuItem id="upgradeFirmware">
        <Name>Upgrade Tasmota Firmware...</Name>
        <CallbackMethod>menuUpgradeFirmware</CallbackMethod>
        <ButtonTitle>Upgrade</ButtonTitle>
        <ConfigUI>
            <Field id="targetDevice" type="menu">
                <Label>Device:</Label>
                <List class="self" filter="" method="pickTasmotaDeviceWithStatus" dynamicReload="true"/>
            </Field>
            <Field id="note" type="label" fontColor="darkgray">
                <Label>Plugin auto-detects ESP architecture and uses the matching official Tasmota OTA URL. Device reboots and is unavailable for ~30-60 seconds.</Label>
            </Field>
        </ConfigUI>
    </MenuItem>

    <MenuItem id="openDevicePage">
        <Name>Open Tasmota Device Web UI...</Name>
        <CallbackMethod>menuOpenDevicePage</CallbackMethod>
        <ButtonTitle>Open</ButtonTitle>
        <ConfigUI>
            <Field id="targetDevice" type="menu">
                <Label>Device:</Label>
                <List class="self" filter="" method="pickTasmotaDevice" dynamicReload="true"/>
            </Field>
            <Field id="note" type="label" fontColor="darkgray">
                <Label>Opens the device's main web page in the default browser on the Indigo Mac. (For firmware upgrades, use the Upgrade Tasmota Firmware menu.)</Label>
            </Field>
        </ConfigUI>
    </MenuItem>

    <MenuItem id="toggleTimestamps">
        <Name>Toggle Timestamps in Log (on/off)</Name>
        <CallbackMethod>menuToggleTimestamps</CallbackMethod>
    </MenuItem>

    <MenuItem id="sep1" isSeparator="true"/>

    <MenuItem id="showPluginInfo">
        <Name>Show Plugin Info</Name>
        <CallbackMethod>showPluginInfo</CallbackMethod>
    </MenuItem>

</MenuItems>
