<?xml version="1.0" encoding="UTF-8"?>
<MenuItems>

    <MenuItem id="discoverDevices">
        <Name>Discover Tasmota Devices</Name>
        <CallbackMethod>discoverDevices</CallbackMethod>
    </MenuItem>

    <MenuItem id="listSeenDevices">
        <Name>List Seen Devices</Name>
        <CallbackMethod>listSeenDevices</CallbackMethod>
    </MenuItem>

    <MenuItem id="dumpDiscoveryCache">
        <Name>Dump Discovery Cache to Log</Name>
        <CallbackMethod>dumpDiscoveryCache</CallbackMethod>
    </MenuItem>

    <MenuItem id="scanNetwork">
        <Name>Scan Network for Tasmota Devices...</Name>
        <CallbackMethod>scanNetwork</CallbackMethod>
        <ButtonTitle>Scan</ButtonTitle>
        <ConfigUI>
            <Field id="ranges" type="textfield" defaultValue="">
                <Label>IP Range:</Label>
                <Description>Pre-filled with this Mac's local subnets + the broker's subnet. Edit if needed. Supports CIDR (192.168.4.0/24), range (192.168.4.100-200), single IP, or comma-separated mix. Max 512 hosts.</Description>
            </Field>
        </ConfigUI>
    </MenuItem>

    <MenuItem id="sep1" isSeparator="true"/>

    <MenuItem id="showPluginInfo">
        <Name>Show Plugin Info</Name>
        <CallbackMethod>showPluginInfo</CallbackMethod>
    </MenuItem>

</MenuItems>
