<?xml version="1.0" encoding="UTF-8"?>
<Events>

    <Event id="deviceOnline">
        <Name>Tasmota Device Came Online</Name>
        <ConfigUI>
            <Field id="targetAddress" type="textfield" defaultValue="">
                <Label>MAC Address (blank = any device):</Label>
            </Field>
        </ConfigUI>
    </Event>

    <Event id="deviceOffline">
        <Name>Tasmota Device Went Offline</Name>
        <ConfigUI>
            <Field id="targetAddress" type="textfield" defaultValue="">
                <Label>MAC Address (blank = any device):</Label>
            </Field>
        </ConfigUI>
    </Event>

    <Event id="newDeviceDiscovered">
        <Name>New Tasmota Device Discovered</Name>
        <ConfigUI>
            <Field id="info" type="label">
                <Label>Fires whenever a previously-unseen MAC publishes a discovery config payload.</Label>
            </Field>
        </ConfigUI>
    </Event>

    <Event id="buttonPressed">
        <Name>Tasmota Button Pressed</Name>
        <ConfigUI>
            <Field id="targetAddress" type="textfield" defaultValue="">
                <Label>MAC Address (blank = any):</Label>
            </Field>
            <Field id="targetButton" type="textfield" defaultValue="">
                <Label>Button Number (blank = any):</Label>
                <Description>1-8 for multi-button devices, blank to match any button on the target device.</Description>
            </Field>
            <Field id="targetAction" type="menu" defaultValue="">
                <Label>Action:</Label>
                <List>
                    <Option value="">Any action</Option>
                    <Option value="SINGLE">Single press</Option>
                    <Option value="DOUBLE">Double press</Option>
                    <Option value="TRIPLE">Triple press</Option>
                    <Option value="QUAD">Quadruple press</Option>
                    <Option value="PENTA">Quintuple press</Option>
                    <Option value="HOLD">Long hold</Option>
                    <Option value="CLEAR">Released</Option>
                </List>
            </Field>
        </ConfigUI>
    </Event>

</Events>
